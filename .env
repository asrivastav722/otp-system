# The port the Express server will run on
PORT=8080

# The secret key required in the "x-api-key" header
# Change this to something unique for your Fixr app
API_KEY=my_super_secret_otp_key_123

# The Local IP of your Android Phone/SIM Gateway
# Make sure your phone and PC are on the same Wi-Fi
GATEWAY_URL=http://192.168.1.10:8080